# Multi-stage build for boring-agent base image
# Usage: docker build -f Dockerfile.agent -t borechestrator/agent:latest .

FROM rust:1-slim AS builder

RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY Cargo.toml Cargo.lock* ./
COPY crates/ crates/

RUN cargo build --release -p boring-agent

# ── Runtime image ────────────────────────────────────────────────
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y \
    ca-certificates \
    git \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create non-root user
RUN useradd -m -s /bin/bash agent
USER agent
WORKDIR /workspace

COPY --from=builder /build/target/release/boring-agent /usr/local/bin/boring-agent

# Extend this image to add your AI CLI tool:
#
#   FROM borechestrator/agent:latest
#   USER root
#   RUN curl -fsSL https://claude.ai/install.sh | sh
#   USER agent

ENTRYPOINT ["boring-agent"]
