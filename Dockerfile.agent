FROM rust:1-slim AS builder

WORKDIR /build
COPY . .
RUN cargo build --release -p boring-agent

FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/target/release/boring-agent /usr/local/bin/boring-agent

# Agent images should install their AI CLI tool here.
# Example for Claude:
# RUN curl -sSf https://claude.ai/install.sh | sh

ENTRYPOINT ["boring-agent"]
