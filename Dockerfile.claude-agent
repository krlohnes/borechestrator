# Agent image with boring-agent (plumbing) + Claude Code (AI)
# Build: docker build -f Dockerfile.claude-agent -t borechestrator/claude-agent:latest .

FROM rust:1-bookworm AS builder
RUN apt-get update && apt-get install -y pkg-config libssl-dev && rm -rf /var/lib/apt/lists/*
WORKDIR /build
COPY Cargo.toml Cargo.lock* ./
COPY crates/ crates/
RUN cargo build --release -p boring-agent

FROM node:22-bookworm-slim

RUN apt-get update && apt-get install -y ca-certificates git curl && rm -rf /var/lib/apt/lists/*
RUN npm install -g @anthropic-ai/claude-code

COPY --from=builder /build/target/release/boring-agent /usr/local/bin/boring-agent

RUN useradd -m -s /bin/bash agent
USER agent
WORKDIR /workspace

# boring-agent handles: git clone, S3 state → .boring/, run command, .boring/ → S3, git push
ENTRYPOINT ["boring-agent"]
